# Get a key at https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# OPTIONAL — multi-key parallel ingest. When set, the daily scheduler
# partitions work across multiple API keys (Riot's rate limit is per-
# key, so 3 keys = 3× sustained throughput, 9 keys = 9×). Falls back
# to RIOT_API_KEY above when empty.
#
# How to get more keys: each Riot dev account gets one Personal Key
# (20 req/s · 100/2min). Create separate accounts (different email +
# Riot ID per account) — explicitly allowed for internal tools.
#
# Example with 3 keys: 1 per tier (Master / GM / Chall), each handling
# all 3 regions (EUW / KR / NA).
# RIOT_API_KEYS=RGAPI-aaaaa,RGAPI-bbbbb,RGAPI-ccccc

# euw1, kr, na1, br1, eun1, jp1, la1, la2, oc1, tr1, ru
PLATFORM=euw1

# europe (EUW/EUNE/TR/RU), americas (NA/BR/LAN/LAS/OCE), asia (KR/JP), sea
REGION=europe

# Min games for inclusion in scoring
MIN_GAMES=20

# Match history depth per player
MATCH_HISTORY_COUNT=30

# SQLite path (relative to backend/)
DATABASE_URL=sqlite:///./data/scouting.db

# Current patch (for filtering / display)
CURRENT_PATCH=14.9

# Auth — change this to a long random string in prod
JWT_SECRET=change-me-please-very-long-random-string
JWT_EXPIRY_HOURS=72

# lol.fandom.com / Leaguepedia (optional but strongly recommended).
#
# This is the Fandom (lol.fandom.com) Cargo API. Anonymous usage is rate-
# limited to ~1 request / 60 seconds after a handful of calls — basically
# unusable for the EU pro sync. With an authenticated bot password you get
# a much higher quota.
#
# How to get credentials (2 minutes):
#   1. Create / sign in to a regular Fandom account at https://www.fandom.com
#   2. Go to https://lol.fandom.com/wiki/Special:BotPasswords (logged in)
#   3. Create a new bot password — give it any label, e.g. "scouting"
#   4. Tick at least the "Read" permission scope (we never write)
#   5. Copy BOTH the username (which Fandom returns as "YourFandomName@scouting"
#      — note the @label suffix) AND the generated password.
#
# These are *exactly* the lol.fandom.com bot credentials, NOT a separate
# Leaguepedia-only login (Leaguepedia and lol.fandom.com are the same service).
FANDOM_USERNAME=
FANDOM_PASSWORD=

# Legacy aliases (still honored for backwards compatibility — same meaning):
# LP_USERNAME=
# LP_PASSWORD=

# ---- Alerts (optional) ----
# Discord: server settings → Integrations → Webhooks → New Webhook → copy URL.
# Slack:   api.slack.com/apps → your app → Incoming Webhooks → Add New Webhook.
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Public URL of the deployed frontend (Vercel/Fly/etc.). Used as the link
# target in alert messages. Leave empty to omit the link.
PUBLIC_APP_URL=

# Alert thresholds
ALERT_CSS_MIN=70.0
ALERT_CSS_DELTA=4.0
ALERT_WINRATE_STREAK_MIN=6

# ---- Daily ladder ingest scheduler (optional) ----
# When enabled, an in-process asyncio loop fires the multi-key ingest
# job every day at HH:MM (server local time). Logged in /admin/jobs.
# Disable + manual trigger via POST /admin/scheduler/trigger-now.
DAILY_INGEST_ENABLED=false
DAILY_INGEST_HOUR=4
DAILY_INGEST_MINUTE=0

# Comma-separated platform codes
DAILY_INGEST_REGIONS=euw1,kr,na1
# Comma-separated tiers (challenger, grandmaster, master)
DAILY_INGEST_TIERS=challenger,grandmaster,master
# Per-tier player cap (per region)
DAILY_INGEST_PLAYERS_PER_TIER=500
# Match history depth per player
DAILY_INGEST_GAMES_PER_PLAYER=30

# Key-to-work assignment strategy:
#   tier         — 1 key per tier (default; matches the 3-key chall/gm/master split)
#   region       — 1 key per region (3 keys for euw/kr/na)
#   tier_region  — 1 key per (tier × region) cell (best with 9 keys)
#   round_robin  — distribute work units evenly across all keys
DAILY_INGEST_PARTITION=tier
